# Base de datos PostgreSQL
DATABASE_URL="postgresql://usuario:password@localhost:5432/his_db?schema=public"

# Ajustes opcionales del pool Prisma para desarrollo (Next dev)
# PRISMA_DEV_CONNECTION_LIMIT="1"
# PRISMA_DEV_POOL_TIMEOUT="60"

# Clerk - Autenticación
# Obtener desde https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Rutas de Clerk
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Configuración de la aplicación
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_NAME="Sistema HIS"

# Seguridad
# Tiempo de expiración de sesión en segundos (8 horas)
SESSION_MAX_AGE=28800
