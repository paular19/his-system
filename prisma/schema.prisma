// ============================================
// OBRA SOCIAL (LEGACY)
// ============================================

// Modelo para Plan de Obra Social
model PlanObraSocial {
  obraSocialId Int    @map("OSID")
  id           Int    @map("PosID")
  descripcion  String @map("PosDescrip") @db.VarChar(200)

  // Información adicional
  norma          String? @map("PosNorma") @db.Text
  exportarIOSE   String? @map("PosExportIOSE") @db.Char(1)
  codigoAnterior String? @map("PosCodOld") @db.VarChar(50)

  // Administrativo
  estado          String   @map("PosEstado") @db.Char(1)
  fechaEstado     DateTime @map("PosFchEstado") @db.Timestamp(6)
  usuarioRegistro String   @map("UsuCodig") @db.Char(10)

  // Relaciones
  obraSocial ObraSocial @relation(fields: [obraSocialId], references: [id])

  pacientes Paciente[]
  turnos    Turno[]
  ingresos  Ingreso[]
  ordenes   Orden[]
  practicas Practica[]
  lotes     LoteFacturacion[] @relation("LotePlan")

  @@id([obraSocialId, id])
  @@index([estado])
  @@map("PlanOSoc")
}

// Actualizar modelo ObraSocial existente
model ObraSocial {
  id               Int      @id @map("OSID")
  nombre           String   @map("OSNom") @db.VarChar(200)
  requiereCoseguro String?  @map("OSReqCoseg") @db.Char(1)
  estado           String   @map("OSEstad") @db.Char(1)
  fechaEstado      DateTime @map("OSFchEst") @db.Timestamp(6)

  // Relaciones
  planes    PlanObraSocial[]
  pacientes Paciente[]
  turnos    Turno[]
  ingresos  Ingreso[]
  ordenes   Orden[]
  practicas Practica[]
  lotes     LoteFacturacion[] @relation("LoteObraSocial")

  @@map("ObraSocial")
}

model Orden {
  puestoNumero Int @map("PueNum")
  numero       Int @map("OrdNum")

  // Relación con Ingreso
  ingresoId Int? @map("IngID")

  // Datos de la orden
  descripcion  String?  @map("OrdDescrip") @db.VarChar(255)
  fechaEmision DateTime @map("OrdFchEmi") @db.Timestamp(6)
  fechaPedido  DateTime @map("OrdFchPed") @db.Timestamp(6)

  // Número de autorización (generalmente vacío a este nivel)
  numeroAutorizacion String? @map("OrdNumAut") @db.VarChar(15)

  // Paciente y OS
  pacienteId     Int?   @map("PacID")
  nombrePaciente String @map("OrdNom") @db.VarChar(50)
  numeroAfiliado String @map("OrdNumAfil") @db.VarChar(30)
  obraSocialId   Int    @map("OSID")
  planId         Int    @map("PosID")

  // Coseguro
  obraSocialCoseguroId Int? @map("OSIDCoseg")
  planCoseguroId       Int? @map("PosIDCoseg")

  // Profesional prescriptor
  profesionalId Int @map("PrfID")

  // Tipo de orden
  tipoOrdenCodigo String @map("TorCodig") @db.Char(3)

  // Patología
  patologiaId          Int?    @map("PatID")
  descripcionPatologia String? @map("OrdPatDescrip") @db.VarChar(300)

  // Importes
  importeTotal    Decimal? @map("OrdImpTotal") @db.Decimal(12, 2)
  importeCargoPac Decimal? @map("OprImpCargoPac") @db.Decimal(12, 2)

  // Modo modular (opcional)
  titularModular       String? @map("OrdTitularModular") @db.VarChar(100)
  imprimirPorDuplicado Boolean @default(false) @map("OrdImprimirDuplicado")

  // Administrativo
  estado          String   @map("OrdEstad") @db.Char(1)
  fechaEstado     DateTime @map("OrdFchEst") @db.Timestamp(6)
  usuarioRegistro String   @map("UsuCodig") @db.Char(10)

  // Relaciones
  ingreso     Ingreso?        @relation(fields: [ingresoId], references: [id])
  obraSocial  ObraSocial      @relation(fields: [obraSocialId], references: [id])
  plan        PlanObraSocial  @relation(fields: [obraSocialId, planId], references: [obraSocialId, id])
  profesional Profesional     @relation("OrdenPrescriptor", fields: [profesionalId], references: [id])
  tipoOrden   TipoOrden       @relation(fields: [tipoOrdenCodigo], references: [codigo])
  items       OrdenPractica[] // Aquí están las prácticas con autorizaciones

  @@id([puestoNumero, numero])
  @@index([ingresoId])
  @@index([estado])
  @@index([fechaEmision])
  @@map("Orden")
}

model OrdenPractica {
  puestoNumero Int @map("PueNum")
  ordenNumero  Int @map("OrdNum")
  item         Int @map("OprItem")

  // Práctica
  convenioId            Int     @map("NConCodig")
  codigoPractica        String  @map("NPrCodig") @db.Char(8)
  convenioValorId       Int?    @map("NConCodigValor")
  tipoDiferencialCodigo String? @map("NpfCodig") @db.Char(3)

  // ⭐ NÚMERO DE AUTORIZACIÓN - ESTE ES EL CAMPO CLAVE
  numeroAutorizacion String? @map("OprNumAut") @db.VarChar(15)

  // Cantidades y valores
  fecha                  DateTime @map("OprFch") @db.Timestamp(6)
  cantidad               Decimal  @map("OprCant") @db.Decimal(8, 2)
  cantidadModuloIntegral Decimal? @map("OprCantModInt") @db.Decimal(5, 2)

  // Importes
  importeTotal         Decimal? @map("OprImpTotal") @db.Decimal(12, 2)
  importeCargoPaciente Decimal? @map("OprImpCargoPac") @db.Decimal(12, 2)
  porcentajeCargoPac   Decimal? @map("OprPorcenCargoPac") @db.Decimal(5, 2)

  // Facturación
  tipoFacturacion      String  @map("OprTipFact") @db.Char(1)
  modulo               String? @map("OprModulo") @db.Char(8)
  titularModular       String? @map("OprTitularModular") @db.VarChar(100)
  imprimirPorDuplicado Boolean @default(false) @map("OprImprimirDuplicado")
  efectorMatricula     Int?    @map("OprMatric")

  // Vinculación con práctica ejecutada
  practicaId Int? @map("PraID")

  // Relaciones
  orden               Orden                @relation(fields: [puestoNumero, ordenNumero], references: [puestoNumero, numero], onDelete: Cascade, onUpdate: Cascade)
  practica            Practica?            @relation(fields: [practicaId], references: [id])
  nomencladorPractica NomencladorPractica? @relation(fields: [convenioId, codigoPractica], references: [convenioId, codigo])

  @@id([puestoNumero, ordenNumero, item])
  @@index([practicaId])
  @@map("OrdenPrac")
}

model Practica {
  id        Int @id @default(autoincrement()) @map("PraID")
  ingresoId Int @map("IngID")

  // Práctica
  convenioId      Int    @map("NConCodig")
  codigoPractica  String @map("NPrCodig") @db.VarChar(8)
  convenioValorId Int    @map("NConCodigValor")

  // Fechas y cantidades
  fecha    DateTime @map("PraFch") @db.Timestamp(6)
  cantidad Decimal  @map("PraCant") @db.Decimal(8, 2)

  // ⭐ NÚMERO DE AUTORIZACIÓN (copiado desde OrdenPractica)
  numeroAutorizacion    String? @map("PraNumAut") @db.VarChar(50)
  matriculaEspecialista Int?    @map("PraMatEsp")
  matriculaAnestesista  Int?    @map("PraMatAne")

  // Obra Social
  obraSocialId Int? @map("OSID")
  planId       Int? @map("PosID")

  // Facturación
  facturable      Boolean  @map("PraFacturar")
  motivoNoFactura String?  @map("PraMotNoFact") @db.Char(2)
  importeTotal    Decimal? @map("PraImpTotal") @db.Decimal(12, 2)

  // Relación con Orden
  puestoNumero Int? @map("PueNum")
  ordenNumero  Int? @map("OrdNum")
  ordenItem    Int? @map("OprItem")

  // Administrativo
  estado          String?   @map("PraEstad") @db.Char(1)
  usuarioRegistro String    @map("UsuCodig") @db.Char(10)
  fechaUsuario    DateTime? @map("PraFchUsu") @db.Timestamp(6)

  // Relaciones
  ingreso             Ingreso              @relation(fields: [ingresoId], references: [id])
  obraSocial          ObraSocial?          @relation(fields: [obraSocialId], references: [id])
  plan                PlanObraSocial?      @relation(fields: [obraSocialId, planId], references: [obraSocialId, id])
  ordenPractica       OrdenPractica[]
  nomencladorPractica NomencladorPractica? @relation(fields: [convenioId, codigoPractica], references: [convenioId, codigo])

  @@index([ingresoId])
  @@index([fecha])
  @@map("Practica")
}

model TipoOrden {
  codigo      String @id @map("TorCodig") @db.Char(3)
  descripcion String @map("TorDescrip") @db.VarChar(100)

  ordenes Orden[]

  @@map("TipoOrden")
}

// Modelo Prisma para el nomenclador
model NomencladorPractica {
  convenioId  Int     @map("NConCodig")
  codigo      String  @map("NPrCodig") @db.Char(8)
  descripcion String  @map("NPrDescrip") @db.VarChar(500)
  categoriaId String? @map("NcpCodig") @db.Char(5)

  // Desglose de valores por componente (opcional)
  valorEspecialista Decimal? @map("NPrValEsp") @db.Decimal(18, 2)
  valorAyudante     Decimal? @map("NPrValAyu") @db.Decimal(18, 2)
  valorAnestesista  Decimal? @map("NPrValAne") @db.Decimal(18, 2)
  valorGastos       Decimal? @map("NPrValGto") @db.Decimal(18, 2)

  // Relaciones
  ordenPracticas OrdenPractica[]
  practicas      Practica[]

  @@id([convenioId, codigo])
  @@map("NPractica")
}

// ============================================
// FACTURACIÓN — LOTES
// ============================================

model LoteFacturacion {
  id     Int      @id @default(autoincrement()) @map("LotID")
  numero Int      @map("LotNro")
  fecha  DateTime @map("LotFecha") @db.Timestamp(6)

  // Periodo "2026-04"
  periodo String @map("LotPeriodo") @db.VarChar(7)

  // Cliente
  obraSocialId Int? @map("OSID")
  planId       Int? @map("PosID")

  // Filtros de creación
  tipoIngresoCodigo String? @map("TigCodig") @db.Char(3)

  // Tipo: PRACTICAS | MEDICAMENTOS
  tipo String @map("LotTipo") @db.VarChar(20)

  // Rango numérico opcional (ej: kinesio, radiografía)
  rangoDesde Int? @map("LotRangoDesde")
  rangoHasta Int? @map("LotRangoHasta")

  // Resumen
  sedeId       Int?    @map("SedID")
  descripcion  String? @map("LotDescrip") @db.VarChar(500)
  concepto     String? @map("LotConcepto") @db.VarChar(200)
  importeTotal Decimal @default(0) @map("LotImpTotal") @db.Decimal(18, 2)

  // Origen del lote: null=normal, IPS_TXT=importado desde planilla IPS
  origen String? @map("LotOrigen") @db.VarChar(20)

  // Estado: PEN=Pendiente, CON=Confirmado, ANU=Anulado
  estado      String   @map("LotEstado") @db.Char(3)
  fechaEstado DateTime @map("LotFchEstado") @db.Timestamp(6)
  usuario     String   @map("UsuCodig") @db.Char(10)

  obraSocial  ObraSocial?           @relation("LoteObraSocial", fields: [obraSocialId], references: [id])
  plan        PlanObraSocial?       @relation("LotePlan", fields: [obraSocialId, planId], references: [obraSocialId, id])
  items       LoteFacturacionItem[]
  itemsIPSTxt LoteIPSTxtItem[]

  @@index([estado])
  @@index([periodo])
  @@index([obraSocialId])
  @@map("LoteFacturacion")
}

model LoteFacturacionItem {
  id        Int @id @default(autoincrement()) @map("LItID")
  loteId    Int @map("LotID")
  ingresoId Int @map("IngID")

  incluido     Boolean @default(true) @map("LItIncluido")
  importeTotal Decimal @default(0) @map("LItImpTotal") @db.Decimal(18, 2)

  lote    LoteFacturacion @relation(fields: [loteId], references: [id], onDelete: Cascade)
  ingreso Ingreso         @relation("IngresoLotes", fields: [ingresoId], references: [id])

  @@unique([loteId, ingresoId])
  @@index([loteId])
  @@map("LoteFacturacionItem")
}

// ============================================
// FACTURACIÓN — LOTE IPS DESDE PLANILLA TXT
// ============================================

model LoteIPSTxtItem {
  id     Int @id @default(autoincrement()) @map("LipID")
  loteId Int @map("LotID")

  // Datos del afiliado
  afiliadoDoc String @map("LipAfilDoc") @db.VarChar(20)
  afiliadoNom String @map("LipAfilNom") @db.VarChar(200)

  // Datos de la prestación
  nroOrden       String    @map("LipNroOrden") @db.VarChar(20)
  fechaRealiz    DateTime? @map("LipFchRealiz") @db.Timestamp(6)
  servicioCodigo String    @map("LipServCod") @db.VarChar(20)
  servicioNombre String    @map("LipServNom") @db.VarChar(500)
  cantidad       Int       @map("LipCantidad")

  // Importes del TXT
  impEsp   Decimal @default(0) @map("LipImpEsp") @db.Decimal(18, 2)
  impAyu   Decimal @default(0) @map("LipImpAyu") @db.Decimal(18, 2)
  impAne   Decimal @default(0) @map("LipImpAne") @db.Decimal(18, 2)
  impGto   Decimal @default(0) @map("LipImpGto") @db.Decimal(18, 2)
  impTotal Decimal @default(0) @map("LipImpTotal") @db.Decimal(18, 2)

  // Importe tras aplicar PROMEDI (40%)
  importePromedi Decimal? @map("LipImpPromedi") @db.Decimal(18, 2)

  lote LoteFacturacion @relation(fields: [loteId], references: [id], onDelete: Cascade)

  @@index([loteId])
  @@map("LoteIPSTxtItem")
}
