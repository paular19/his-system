// ============================================
// SCHEMA PRISMA - SISTEMA HIS
// Fuente de verdad: base legacy compatible
// No modificar @map ni nombres de columnas
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// ENTIDADES PRINCIPALES
// ============================================

model Paciente {
  id              Int  @id @default(autoincrement()) @map("PacID")
  historiaClinica Int? @unique @map("PacHC")

  // Identificación
  apellido        String    @map("PacApell") @db.VarChar(100)
  nombre          String    @map("PacNom") @db.VarChar(100)
  nombreCompleto  String    @map("PacNomCom") @db.VarChar(200)
  tipoDocumento   String?   @map("PacTipDoc") @db.Char(3)
  numeroDocumento Int?      @unique @map("PacNroDoc")
  cuil            Decimal?  @map("PacCUIL") @db.Decimal(11, 0)
  fechaNacimiento DateTime? @map("PacFchNac") @db.Timestamp(6)

  // Demografía
  sexo        String? @map("PacSexo") @db.Char(1)
  estadoCivil String? @map("PacEstCiv") @db.Char(1)
  paisId      Int?    @map("PaiID")
  profesionId Int?    @map("PfeID")

  // Ubicación
  domicilio   String? @map("PacDomic") @db.VarChar(200)
  provinciaId Int?    @map("PrvID")
  localidadId Int?    @map("LodID")
  barrioId    Int?    @map("BarID")

  // Contacto
  telefonoFijo    String? @map("PacTelef") @db.VarChar(50)
  telefonoLaboral String? @map("PacTelLab") @db.VarChar(50)
  celular1        String? @map("PacTelCel1") @db.VarChar(50)
  celular2        String? @map("PacTelCel2") @db.VarChar(50)
  email           String? @map("PacEmail") @db.VarChar(100)

  // Obra Social
  obraSocialId         Int?    @map("OSID")
  planId               Int?    @map("PosID")
  numeroAfiliado       String? @map("PacOSNroAf") @db.VarChar(50)
  obraSocialCoseguroId Int?    @map("OSIDCoseguro")

  // Tutor (para menores/incapaces)
  nombreTutor   String? @map("PacTutor") @db.VarChar(100)
  telefonoTutor String? @map("PacTutTelef") @db.VarChar(50)
  empleoTutor   String? @map("PacTutEmpleo") @db.VarChar(100)

  // Administrativo
  observaciones     String?  @map("PacObser") @db.Text
  usuarioAlta       String   @map("UsuCodig") @db.Char(10)
  fechaAlta         DateTime @map("PacFchIni") @db.Timestamp(6)
  fechaModificacion DateTime @map("PacFchEst") @db.Timestamp(6)
  gravidadId        Int?     @map("GraID")

  // Relaciones
  pais                Pais?               @relation(fields: [paisId], references: [id])
  provincia           Provincia?          @relation("PacienteProvincia", fields: [provinciaId], references: [id])
  localidad           Localidad?          @relation("PacienteLocalidad", fields: [provinciaId, localidadId], references: [provinciaId, id])
  barrio              Barrio?             @relation("PacienteBarrio", fields: [provinciaId, localidadId, barrioId], references: [provinciaId, localidadId, id])
  profesion           Profesion?          @relation(fields: [profesionId], references: [id])
  obraSocial          ObraSocial?         @relation(fields: [obraSocialId], references: [id])
  plan                PlanObraSocial?     @relation(fields: [obraSocialId, planId], references: [obraSocialId, id])
  turnos              Turno[]
  ingresos            Ingreso[]
  movimientos         MovimientoIngreso[]
  pacienteHistorial   PacienteHistorial[]
  cirugiasProgramadas CirugiaProgramada[]

  @@index([numeroDocumento])
  @@index([apellido, nombre])
  @@map("Paciente")
}

model PacienteHistorial {
  id         Int @id @default(autoincrement()) @map("PacHisID")
  pacienteId Int @map("PacID")

  tipoCambio    String   @map("PacHisTipoCambio") @db.Char(1)
  usuarioCambio String   @map("PacHisUsuCambio") @db.Char(10)
  fechaCambio   DateTime @map("PacHisFchCambio") @db.Timestamp(6)

  paciente Paciente @relation(fields: [pacienteId], references: [id])

  @@map("PacienteHis")
}

model Turno {
  profesionalId Int      @map("PrfID")
  fechaTurno    DateTime @map("TurFecha") @db.Timestamp(6)

  tipoTurnoCodigo String? @map("TTuCodig") @db.Char(5)
  duracion        Int?    @map("TurDurTur") @db.SmallInt

  pacienteId      Int?    @map("PacID")
  tipoDocumento   String? @map("TdoCodig") @db.Char(3)
  numeroDocumento Int?    @map("PacNroDoc")
  nombrePaciente  String? @map("TurPacNom") @db.VarChar(200)
  telefono        String? @map("TurTelef") @db.VarChar(50)
  email           String? @map("TurEmail") @db.VarChar(100)

  obraSocialId   Int?    @map("OSID")
  planId         Int?    @map("PosID")
  coseguroId     Int?    @map("OSCodigCoseguro")
  numeroAfiliado String? @map("TurOSNroAf") @db.VarChar(50)

  estado      String?   @map("TurEstad") @db.Char(1)
  fechaEstado DateTime? @map("TurFchEst") @db.Timestamp(6)

  fechaSolicitud   DateTime? @map("TurFchSol") @db.Timestamp(6)
  fechaLlegada     DateTime? @map("TurFchLlego") @db.Timestamp(6)
  fechaAtencion    DateTime? @map("TurFchAten") @db.Timestamp(6)
  usuarioSolicitud String?   @map("TurUsuSol") @db.Char(10)
  usuarioLlegada   String?   @map("TurUsuLlego") @db.Char(10)
  usuarioAtencion  String?   @map("TurUsuAten") @db.Char(10)

  importe          Decimal? @map("TurImporte") @db.Decimal(18, 2)
  senia            Decimal? @map("TurImpSenia") @db.Decimal(18, 2)
  sinCargo         Boolean? @map("TurSinCargo")
  numeroBono       String?  @map("TurNroBono") @db.VarChar(50)
  numeroReferencia String?  @map("TurNroRef") @db.VarChar(50)

  observaciones   String? @map("TurObserv") @db.VarChar(500)
  sedeId          Int?    @map("SedID")
  ubicacionId     Int?    @map("UbiID")
  ingresoId       Int?    @map("IngID")
  usuarioRegistro String  @map("UsuCodig") @db.Char(10)

  profesional    Profesional?     @relation(fields: [profesionalId], references: [id])
  paciente       Paciente?        @relation(fields: [pacienteId], references: [id])
  ingreso        Ingreso?         @relation(fields: [ingresoId], references: [id])
  obraSocial     ObraSocial?      @relation(fields: [obraSocialId], references: [id])
  plan           PlanObraSocial?  @relation(fields: [obraSocialId, planId], references: [obraSocialId, id])
  turnoHistorial TurnoHistorial[]

  @@id([profesionalId, fechaTurno])
  @@index([pacienteId])
  @@index([fechaTurno])
  @@index([estado])
  @@map("Turno")
}

model TurnoHistorial {
  id            Int      @id @default(autoincrement()) @map("TurID")
  profesionalId Int      @map("PrfID")
  fechaTurno    DateTime @map("TurFecha") @db.Timestamp(6)

  tipoCambio    String    @map("TurTipoCambio") @db.Char(1)
  usuarioCambio String    @map("TurUsuCambio") @db.Char(10)
  fechaCambio   DateTime? @map("TurFchCambio") @db.Timestamp(6)

  turno Turno @relation(fields: [profesionalId, fechaTurno], references: [profesionalId, fechaTurno])

  @@map("TurnoHis")
}

model TurnoExtra {
  profesionalId Int      @map("PrfID")
  fecha         DateTime @map("TexFecha") @db.Timestamp(6)
  duracion      Int      @map("TexDurTur") @db.SmallInt
  fechaSistema  DateTime @map("TexFchSis") @db.Timestamp(6)
  usuario       String   @map("UsuCodig") @db.Char(10)

  profesional Profesional @relation(fields: [profesionalId], references: [id])

  @@id([profesionalId, fecha])
  @@map("TurnosExtra")
}

model Ingreso {
  id                Int    @id @default(autoincrement()) @map("IngID")
  tipoIngresoCodigo String @map("TigCodig") @db.Char(3)
  numeroIngreso     Int    @map("IngNro")

  pacienteId      Int?      @map("PacID")
  nombre          String?   @map("IngNom") @db.VarChar(200)
  fechaNacimiento DateTime? @map("IngFchNac") @db.Timestamp(6)
  edad            Int?      @map("IngEdad") @db.SmallInt

  fechaIngreso        DateTime? @map("IngFchIngreso") @db.Timestamp(6)
  fechaEgreso         DateTime? @map("IngFchEgreso") @db.Timestamp(6)
  fechaEgresoPrevista DateTime? @map("IngFchEgresoPrevista") @db.Timestamp(6)
  fechaObito          DateTime? @map("IngFchObito") @db.Timestamp(6)

  tipoInternacionCodigo          String? @map("TinCodig") @db.Char(3)
  patologiaId                    Int?    @map("PatID")
  descripcionPatologia           String? @map("IngPatDescrip") @db.VarChar(500)
  patologiaDefinitivaId          Int?    @map("IngPatDef")
  descripcionPatologiaDefinitiva String? @map("IngPatDefDescrip") @db.VarChar(500)
  motivoEgresoCodigo             String? @map("MegCodig") @db.Char(2)
  servicioId                     Int?    @map("SerID")

  camaId          Int? @map("CamID")
  tipoOcupacionId Int? @map("TOcuID")
  sedeId          Int? @map("SedID")

  profesionalGuardiaId   Int? @map("PrfIDGuardia")
  profesionalTratanteId  Int? @map("PrfIDTratante")
  centroDerivanteId      Int? @map("CenIDDerivante")
  profesionalDerivanteId Int? @map("PrdIDDerivante")

  obraSocialId   Int?      @map("OSID")
  planId         Int?      @map("PosID")
  numeroAfiliado String?   @map("IngOSNroAf") @db.VarChar(50)
  grupoOS        Decimal?  @map("IngOSGpo") @db.Decimal(5, 2)
  repeticionOS   Decimal?  @map("IngOSRep") @db.Decimal(5, 2)
  pmi            Boolean?  @map("IngOSPmi")
  pmiFechaInicio DateTime? @map("IngOSPmiFchIni") @db.Timestamp(6)
  pmiFechaFin    DateTime? @map("IngOSPmiFchFin") @db.Timestamp(6)

  obraSocialCoseguroId   Int?    @map("OSIDCoseg")
  planCoseguroId         Int?    @map("PosIDCoseg")
  numeroAfiliadoCoseguro String? @map("IngOSNroAfCoseg") @db.VarChar(50)

  artEmpleador          String?   @map("IngARTEmp") @db.VarChar(100)
  artEmpleadorCUIT      Decimal?  @map("IngARTEmpCUIT") @db.Decimal(11, 0)
  artEmpleadorTelefono  String?   @map("IngARTEmpTel") @db.VarChar(50)
  artEmpleadorDomicilio String?   @map("IngARTEmpDom") @db.VarChar(200)
  artNumeroSiniestro    String?   @map("IngARTNumSin") @db.VarChar(50)
  artFechaSiniestro     DateTime? @map("IngARTFchSin") @db.Timestamp(6)

  nombreTutor          String? @map("IngTutor") @db.VarChar(100)
  tipoDocumentoTutor   String? @map("IngTutTipDoc") @db.Char(3)
  numeroDocumentoTutor Int?    @map("IngTutNroDoc")
  empleoTutor          String? @map("IngTutEmpleo") @db.VarChar(100)
  telefonoTutor        String? @map("IngTutTelef") @db.VarChar(50)

  conceptoId         Int?     @map("CtoID")
  cantidad           Decimal? @map("CcdCantidad") @db.Decimal(10, 2)
  numeroAutorizacion String?  @map("IngPraNumAut") @db.VarChar(50)
  senia              Decimal? @map("IngImpSenia") @db.Decimal(18, 2)
  importeTurno       Decimal? @map("IngTurImporte") @db.Decimal(18, 2)
  sinCargo           Boolean? @map("IngSinCargo")

  estado      String?   @map("IngEstad") @db.Char(1)
  fechaEstado DateTime? @map("IngFchEst") @db.Timestamp(6)

  observaciones String?         @map("IngObser") @db.Text
  usuario       String?         @map("UsuCodig") @db.Char(10)
  gravidadId    Int?            @map("GraID")
  obraSocial    ObraSocial?     @relation(fields: [obraSocialId], references: [id])
  plan          PlanObraSocial? @relation(fields: [obraSocialId, planId], references: [obraSocialId, id])

  paciente            Paciente?                @relation(fields: [pacienteId], references: [id])
  tipoIngreso         TipoIngreso              @relation(fields: [tipoIngresoCodigo], references: [codigo])
  tipoInternacion     TipoInternacion?         @relation(fields: [tipoInternacionCodigo], references: [codigo])
  motivoEgreso        MotivoEgreso?            @relation(fields: [motivoEgresoCodigo], references: [codigo])
  profesionalGuardia  Profesional?             @relation("IngresoGuardia", fields: [profesionalGuardiaId], references: [id])
  profesionalTratante Profesional?             @relation("IngresoTratante", fields: [profesionalTratanteId], references: [id])
  cama                Cama?                    @relation(fields: [camaId], references: [id])
  turnos              Turno[]
  ingresoPatologias   IngresoPatologia[]
  movimientosIngreso  MovimientoIngreso[]
  ingresoHistorial    IngresoHistorial[]
  ordenes             Orden[]
  practicas           Practica[]
  informes            InformeHospitalizacion[]
  cirugiasProgramadas CirugiaProgramada[]      @relation("CirugiaProgramadaToIngreso")
  ingresoSubtipo      IngresoSubtipo?
  informeAmbulatorio  InformeAmbulatorio?
  evoluciones         EvolucionIngreso[]
  transferencias      TransferenciaIngreso[]
  medicaciones        MedicacionIngreso[]
  descartables        DescartableIngreso[]
  lotesItems          LoteFacturacionItem[]    @relation("IngresoLotes")

  @@unique([tipoIngresoCodigo, numeroIngreso])
  @@index([pacienteId])
  @@index([fechaIngreso])
  @@index([estado])
  @@map("Ingreso")
}

model IngresoHistorial {
  id        Int @id @default(autoincrement()) @map("IngHisID")
  ingresoId Int @map("IngID")

  tipoCambio    String    @map("IngHisTipoCambio") @db.Char(1)
  usuarioCambio String    @map("IngHisUsuCambio") @db.Char(10)
  fechaCambio   DateTime? @map("IngHisFchCambio") @db.Timestamp(6)

  ingreso Ingreso @relation(fields: [ingresoId], references: [id])

  @@map("IngresoHis")
}

model IngresoPatologia {
  id            Int      @id @default(autoincrement()) @map("InpID")
  ingresoId     Int      @map("IngID")
  patologiaId   Int?     @map("PatID")
  fecha         DateTime @map("InpFecha") @db.Timestamp(6)
  descripcion   String?  @map("InpDescrip") @db.VarChar(500)
  observaciones String?  @map("InpObs") @db.VarChar(500)
  estado        String   @map("InpEstado") @db.Char(1)
  fechaEstado   DateTime @map("InpFchEstado") @db.Timestamp(6)
  usuario       String   @map("UsuCodig") @db.Char(10)

  ingreso Ingreso @relation(fields: [ingresoId], references: [id])

  @@map("IngresoPatologia")
}

model MovimientoIngreso {
  id                   Int       @id @default(autoincrement()) @map("MinID")
  ingresoId            Int?      @map("IngID")
  pacienteId           Int?      @map("PacID")
  tipoMovimientoCodigo String    @map("TmiCodig") @db.Char(3)
  fecha                DateTime? @map("MinFecha") @db.Timestamp(6)
  fechaVencimiento     DateTime? @map("MinFchVto") @db.Timestamp(6)
  concepto             String?   @map("MinConcep") @db.VarChar(200)
  signo                Int       @map("MinSigno") @db.SmallInt
  importe              Decimal   @map("MinImporte") @db.Decimal(18, 2)
  saldo                Decimal   @map("MinSaldo") @db.Decimal(18, 2)
  estado               String    @map("MinEstado") @db.Char(1)
  fechaEstado          DateTime  @map("MinFchEstado") @db.Timestamp(6)
  usuario              String    @map("UsuCodig") @db.Char(10)

  ingreso        Ingreso?              @relation(fields: [ingresoId], references: [id])
  paciente       Paciente?             @relation(fields: [pacienteId], references: [id])
  tipoMovimiento TipoMovimientoIngreso @relation(fields: [tipoMovimientoCodigo], references: [codigo])

  @@index([ingresoId])
  @@index([pacienteId])
  @@map("MovIngreso")
}

model Profesional {
  id                    Int     @id @default(autoincrement()) @map("PrfID")
  nombre                String  @map("PrfNombre") @db.VarChar(200)
  matricula             Int?    @map("PrfMatric")
  especialidadId        Int?    @map("EspID")
  tipoProfesionalCodigo String? @map("TpfCodig") @db.Char(3)

  domicilio    String? @map("PrfDomic") @db.VarChar(200)
  provinciaId  Int?    @map("PrvID")
  localidadId  Int?    @map("LodID")
  codigoPostal String? @map("PrfCP") @db.VarChar(10)
  telefono     String? @map("PrfTelef") @db.VarChar(50)
  celular      String? @map("PrfTelCel") @db.VarChar(50)
  email        String? @map("PrfEmail") @db.VarChar(100)

  estado      String   @map("PrfEstad") @db.Char(1)
  fechaEstado DateTime @map("PrfFchEst") @db.Timestamp(6)
  usuario     String   @map("UsuCodig") @db.Char(10)

  turnos                  Turno[]
  turnosExtra             TurnoExtra[]
  ingresosComoGuardia     Ingreso[]                @relation("IngresoGuardia")
  ingresosComoTratante    Ingreso[]                @relation("IngresoTratante")
  ordenesComoPrescritor   Orden[]                  @relation("OrdenPrescriptor")
  informesComoEfector     InformeHospitalizacion[] @relation("InformeEfector")
  informesComoPrescriptor InformeHospitalizacion[] @relation("InformePrescriptor")
  evoluciones             EvolucionIngreso[]       @relation("EvolucionProfesional")
  transferencias          TransferenciaIngreso[]   @relation("TransferenciaProfesional")
  medicaciones            MedicacionIngreso[]      @relation("MedicacionProfesional")
  descartables            DescartableIngreso[]     @relation("DescartableProfesional")

  @@map("Profesional")
}

// ============================================
// INTERNACIÓN - GESTIÓN DE CAMAS
// ============================================

model Cama {
  id            Int      @id @default(autoincrement()) @map("CamID")
  identificador String   @map("CamIdentif") @db.VarChar(20)
  habitacion    String?  @map("CamHabitacion") @db.VarChar(50)
  sector        String   @map("CamSector") @db.VarChar(30)
  // Sector: PISO | TERAPIA_INTENSIVA | TERAPIA_INTERMEDIA
  estado        String   @map("CamEstado") @db.VarChar(20)
  // Estado: DISPONIBLE | OCUPADA | RESERVADA | MANTENIMIENTO
  observaciones String?  @map("CamObservaciones") @db.VarChar(500)
  sedeId        Int?     @map("SedID")
  usuario       String   @map("UsuCodig") @db.Char(10)
  fechaEstado   DateTime @map("CamFchEstado") @db.Timestamp(6)

  ingresos              Ingreso[]
  cirugiasProgramadas   CirugiaProgramada[]
  transferenciasOrigen  TransferenciaIngreso[] @relation("TransferenciaOrigen")
  transferenciasDestino TransferenciaIngreso[] @relation("TransferenciaDestino")

  @@index([estado])
  @@index([sector])
  @@map("Cama")
}

// ============================================
// INTERNACIÓN — EVOLUCIÓN CLÍNICA
// ============================================

model EvolucionIngreso {
  id        Int      @id @default(autoincrement()) @map("EvoID")
  ingresoId Int      @map("IngID")
  fecha     DateTime @map("EvoFecha") @db.Timestamp(6)

  // Tipo: MEDICA | ENFERMERIA | KINESIO | NUTRICION | SERVICIO_SOCIAL | PSICOLOGIA | OTRO
  tipo        String @map("EvoTipo") @db.VarChar(30)
  descripcion String @map("EvoDescrip") @db.Text

  // Signos vitales (opcionales)
  tensionArterial        String?  @map("EvoTA") @db.VarChar(20)
  frecuenciaCardiaca     Int?     @map("EvoFC") @db.SmallInt
  frecuenciaRespiratoria Int?     @map("EvoFR") @db.SmallInt
  temperatura            Decimal? @map("EvoTemp") @db.Decimal(4, 1)
  saturacionO2           Int?     @map("EvoSpO2") @db.SmallInt

  profesionalId Int?     @map("PrfID")
  usuario       String   @map("UsuCodig") @db.Char(10)
  fechaEstado   DateTime @map("EvoFchEstado") @db.Timestamp(6)

  ingreso     Ingreso      @relation(fields: [ingresoId], references: [id])
  profesional Profesional? @relation("EvolucionProfesional", fields: [profesionalId], references: [id])

  @@index([ingresoId])
  @@index([fecha])
  @@map("EvolucionIngreso")
}

// ============================================
// INTERNACIÓN — TRANSFERENCIA DE CAMA
// ============================================

model TransferenciaIngreso {
  id            Int      @id @default(autoincrement()) @map("TraID")
  ingresoId     Int      @map("IngID")
  camaOrigenId  Int?     @map("CamIDOrigen")
  camaDestinoId Int      @map("CamIDDestino")
  fecha         DateTime @map("TraFecha") @db.Timestamp(6)
  motivo        String?  @map("TraMotivo") @db.VarChar(500)
  profesionalId Int?     @map("PrfID")
  usuario       String   @map("UsuCodig") @db.Char(10)
  fechaEstado   DateTime @map("TraFchEstado") @db.Timestamp(6)

  ingreso     Ingreso      @relation(fields: [ingresoId], references: [id])
  camaOrigen  Cama?        @relation("TransferenciaOrigen", fields: [camaOrigenId], references: [id])
  camaDestino Cama         @relation("TransferenciaDestino", fields: [camaDestinoId], references: [id])
  profesional Profesional? @relation("TransferenciaProfesional", fields: [profesionalId], references: [id])

  @@index([ingresoId])
  @@map("TransferenciaIngreso")
}

// ============================================
// INTERNACIÓN — MEDICACIÓN
// ============================================

model MedicacionIngreso {
  id                Int       @id @default(autoincrement()) @map("MedID")
  ingresoId         Int       @map("IngID")
  nombre            String    @map("MedNombre") @db.VarChar(200)
  dosis             String?   @map("MedDosis") @db.VarChar(100)
  viaAdministracion String?   @map("MedVia") @db.VarChar(50)
  frecuencia        String?   @map("MedFrecuencia") @db.VarChar(100)
  fechaInicio       DateTime  @map("MedFchIni") @db.Timestamp(6)
  fechaFin          DateTime? @map("MedFchFin") @db.Timestamp(6)
  observaciones     String?   @map("MedObs") @db.VarChar(500)

  // Vinculación con autorización (opcional)
  ordenPuestoNumero Int? @map("MedOrdPue")
  ordenNumero       Int? @map("MedOrdNum")

  profesionalId Int?     @map("PrfID")
  // Estado: A=Activo, S=Suspendido, F=Finalizado
  estado        String   @map("MedEstado") @db.Char(1)
  usuario       String   @map("UsuCodig") @db.Char(10)
  fechaEstado   DateTime @map("MedFchEstado") @db.Timestamp(6)

  ingreso     Ingreso      @relation(fields: [ingresoId], references: [id])
  profesional Profesional? @relation("MedicacionProfesional", fields: [profesionalId], references: [id])

  @@index([ingresoId])
  @@map("MedicacionIngreso")
}

model DescartableIngreso {
  id            Int       @id @default(autoincrement()) @map("DesID")
  ingresoId     Int       @map("IngID")
  nombre        String    @map("DesNombre") @db.VarChar(200)
